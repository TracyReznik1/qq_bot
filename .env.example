# DeepSeek
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_URL=https://api.deepseek.com/chat/completions

# OneBot / NapCat / Lagrange HTTP API
ONEBOT_API_URL=http://127.0.0.1:3000
ONEBOT_ACCESS_TOKEN=

# Bot
BOT_NAME=ddy
BOT_PORT=5000
REQUIRE_GROUP_AT=true
BOT_PERSONA=你是一个 QQ 聊天机器人，名字叫 ddy。说话自然、有点傲娇毒舌，但要友好、简洁、靠谱。

# Network
PROXY_URL=http://127.0.0.1:7890
REQUEST_TIMEOUT=18

# Features
SEARCH_MAX_RESULTS=4
HISTORY_TURNS=8
MEMORY_LIMIT=30
MAX_REPLY_CHARS=1700
ENABLE_R18=false

# Data
DATA_DIR=ddy_data
TMP_IMG_DIR=data_tmp
